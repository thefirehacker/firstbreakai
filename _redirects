# Host canonicalization (firstbreakai.pages.dev -> cohort.bubblnet.com) is NOT done here.
# Cloudflare Pages _redirects sources are path-only -- they cannot match by hostname,
# and both hostnames are aliases of the same deployment. Host canonicalization is
# configured as a zone-level Redirect Rule in the Cloudflare dashboard instead.

# Canonicalize trailing index.html -> directory form (avoids /foo/ vs /foo/index.html dupes)
/index.html        /            301
/*/index.html      /:splat/     301

# Journey removed — redirect to roadmap
/journey       /roadmap   301
/journey/      /roadmap   301
/journey/*     /roadmap   301

# No catch-all SPA routing - unknown paths return 404
